    "secret:set": "wrangler secret put SPOTIFY_POLL_TOKEN"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.95.0"
  }
}
