{
  "name": "husayngokal-spotify-poll",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker that pokes /api/spotify/poll every minute. Replaces the unreliable GitHub Actions cron.",
  "scripts": {
